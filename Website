<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Deviation Wraps & Decals — Stand Out. Turn Heads.</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Black+Han+Sans&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet" />
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --black: #0a0a0a;
    --white: #f5f2ec;
    --cream: #f0ebe0;
    --accent: #d94f1e;
    --accent2: #f5a623;
    --mid: #1a1a1a;
    --muted: #888;
    --font-display: 'Black Han Sans', sans-serif;
    --font-body: 'DM Sans', sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--black);
    color: var(--white);
    font-family: var(--font-body);
    overflow-x: hidden;
  }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.2rem 2.5rem;
    background: rgba(10,10,10,0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .logo {
    font-family: var(--font-display);
    font-size: 1.3rem;
    letter-spacing: 0.04em;
    color: var(--white);
    text-decoration: none;
  }
  .logo span { color: var(--accent); }

  .nav-links {
    display: flex; gap: 2rem; list-style: none;
  }
  .nav-links a {
    color: rgba(245,242,236,0.6);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--white); }

  .nav-cta {
    background: var(--accent);
    color: var(--white) !important;
    padding: 0.5rem 1.2rem;
    border-radius: 4px;
    font-weight: 500 !important;
    letter-spacing: 0.04em !important;
  }
  .nav-cta:hover { background: #c44418; color: var(--white) !important; }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 8rem 2.5rem 4rem;
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute; inset: 0; z-index: 0;
    background:
      radial-gradient(ellipse 80% 60% at 60% 50%, rgba(217,79,30,0.12) 0%, transparent 70%),
      radial-gradient(ellipse 50% 40% at 20% 80%, rgba(245,166,35,0.07) 0%, transparent 60%);
  }

  /* animated grid lines */
  .hero-grid {
    position: absolute; inset: 0; z-index: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    animation: grid-drift 30s linear infinite;
  }
  @keyframes grid-drift { from { transform: translateY(0); } to { transform: translateY(60px); } }

  .hero-inner {
    position: relative; z-index: 1;
    text-align: center;
    max-width: 900px;
  }

  .hero-eyebrow {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.5rem;
    padding: 0.4rem 1rem;
    border: 1px solid rgba(217,79,30,0.4);
    border-radius: 100px;
    animation: fadeUp 0.6s ease both;
  }

  .hero-eyebrow::before {
    content: '';
    display: inline-block;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse 2s ease infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:0.3;} }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 10vw, 8rem);
    line-height: 0.92;
    letter-spacing: -0.01em;
    color: var(--white);
    margin-bottom: 1.5rem;
    animation: fadeUp 0.6s 0.1s ease both;
  }
  h1 em {
    font-style: normal;
    color: var(--accent);
    display: block;
  }

  .hero-sub {
    font-size: clamp(1rem, 2vw, 1.2rem);
    font-weight: 300;
    color: rgba(245,242,236,0.65);
    max-width: 560px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
    animation: fadeUp 0.6s 0.2s ease both;
  }

  .hero-actions {
    display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;
    animation: fadeUp 0.6s 0.3s ease both;
  }

  .btn-primary {
    background: var(--accent);
    color: var(--white);
    padding: 0.9rem 2.2rem;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 500;
    font-size: 1rem;
    letter-spacing: 0.02em;
    transition: background 0.2s, transform 0.15s;
    display: inline-flex; align-items: center; gap: 0.5rem;
  }
  .btn-primary:hover { background: #c44418; transform: translateY(-2px); }

  .btn-ghost {
    border: 1px solid rgba(245,242,236,0.25);
    color: var(--white);
    padding: 0.9rem 2.2rem;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 400;
    font-size: 1rem;
    transition: border-color 0.2s, transform 0.15s;
    display: inline-flex; align-items: center; gap: 0.5rem;
  }
  .btn-ghost:hover { border-color: rgba(245,242,236,0.6); transform: translateY(-2px); }

  .hero-stats {
    display: flex; gap: 3rem; justify-content: center; flex-wrap: wrap;
    margin-top: 5rem;
    padding-top: 3rem;
    border-top: 1px solid rgba(255,255,255,0.07);
    animation: fadeUp 0.6s 0.5s ease both;
  }
  .hero-stat-num {
    font-family: var(--font-display);
    font-size: 2.5rem;
    color: var(--white);
    line-height: 1;
  }
  .hero-stat-label {
    font-size: 0.8rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-top: 0.3rem;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* TICKER STRIP */
  .ticker {
    overflow: hidden;
    border-top: 1px solid rgba(255,255,255,0.08);
    border-bottom: 1px solid rgba(255,255,255,0.08);
    background: var(--mid);
    padding: 0.8rem 0;
  }
  .ticker-track {
    display: flex;
    gap: 0;
    white-space: nowrap;
    animation: ticker 25s linear infinite;
    width: max-content;
  }
  .ticker-item {
    display: inline-flex; align-items: center; gap: 1rem;
    padding: 0 2.5rem;
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(245,242,236,0.5);
  }
  .ticker-dot { color: var(--accent); font-size: 1.2em; }
  @keyframes ticker { from { transform: translateX(0); } to { transform: translateX(-50%); } }

  /* SERVICES */
  section { padding: 6rem 2.5rem; }

  .section-label {
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .section-heading {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    line-height: 1.05;
    color: var(--white);
    max-width: 600px;
    margin-bottom: 1rem;
  }

  .section-sub {
    color: rgba(245,242,236,0.5);
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.7;
    max-width: 520px;
    margin-bottom: 3.5rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5px;
    background: rgba(255,255,255,0.06);
    border: 1.5px solid rgba(255,255,255,0.06);
  }

  .service-card {
    background: var(--black);
    padding: 2.5rem 2rem;
    display: flex; flex-direction: column;
    transition: background 0.3s;
    cursor: default;
  }
  .service-card:hover { background: #111; }

  .service-num {
    font-family: var(--font-display);
    font-size: 3rem;
    color: rgba(217,79,30,0.15);
    line-height: 1;
    margin-bottom: 1.2rem;
  }

  .service-icon {
    width: 42px; height: 42px;
    border: 1px solid rgba(217,79,30,0.35);
    border-radius: 8px;
    display: grid; place-items: center;
    margin-bottom: 1.2rem;
    font-size: 1.3rem;
  }

  .service-title {
    font-family: var(--font-display);
    font-size: 1.35rem;
    color: var(--white);
    margin-bottom: 0.7rem;
  }

  .service-desc {
    font-size: 0.9rem;
    color: rgba(245,242,236,0.5);
    line-height: 1.65;
    flex: 1;
  }

  .service-cta {
    margin-top: 1.5rem;
    font-size: 0.82rem;
    color: var(--accent);
    text-decoration: none;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    display: inline-flex; align-items: center; gap: 0.4rem;
    transition: gap 0.2s;
  }
  .service-cta:hover { gap: 0.7rem; }

  /* PROCESS */
  .process-section { background: #080808; }

  .process-steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0;
    margin-top: 3rem;
    position: relative;
  }

  .process-step {
    padding: 2rem;
    border-left: 1px solid rgba(255,255,255,0.07);
    position: relative;
  }
  .process-step:first-child { border-left: none; }

  .step-num {
    font-family: var(--font-display);
    font-size: 4rem;
    color: rgba(255,255,255,0.05);
    line-height: 1;
    position: absolute; top: 1.5rem; right: 1.5rem;
  }

  .step-circle {
    width: 36px; height: 36px;
    border-radius: 50%;
    background: var(--accent);
    display: grid; place-items: center;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--white);
    margin-bottom: 1.2rem;
  }

  .step-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--white);
    margin-bottom: 0.6rem;
  }

  .step-desc {
    font-size: 0.88rem;
    color: rgba(245,242,236,0.45);
    line-height: 1.6;
  }

  /* GALLERY STRIP */
  .gallery-section { padding: 3rem 0; overflow: hidden; }

  .gallery-track {
    display: flex; gap: 1rem;
    animation: gallery-scroll 30s linear infinite;
    width: max-content;
  }

  .gallery-item {
    width: 280px; height: 200px;
    flex-shrink: 0;
    border-radius: 6px;
    overflow: hidden;
    position: relative;
  }

  .gallery-item-bg {
    width: 100%; height: 100%;
    display: grid; place-items: center;
    font-family: var(--font-display);
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.6);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 6px;
  }

  .g1 { background: linear-gradient(135deg, #1a0a00, #3d1f0a); }
  .g2 { background: linear-gradient(135deg, #000a1a, #0a1f3d); }
  .g3 { background: linear-gradient(135deg, #0a1a00, #1a3d0a); }
  .g4 { background: linear-gradient(135deg, #1a001a, #3d0a3d); }
  .g5 { background: linear-gradient(135deg, #1a0a00, #4a1a00); }
  .g6 { background: linear-gradient(135deg, #001a1a, #003d3d); }

  @keyframes gallery-scroll { from { transform: translateX(0); } to { transform: translateX(-50%); } }

  /* TESTIMONIALS */
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-top: 3.5rem;
  }

  .testimonial-card {
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    padding: 2rem;
    position: relative;
  }

  .quote-mark {
    font-family: var(--font-display);
    font-size: 4rem;
    line-height: 1;
    color: var(--accent);
    opacity: 0.3;
    position: absolute;
    top: 1rem; left: 1.5rem;
  }

  .testimonial-text {
    font-size: 0.95rem;
    font-weight: 300;
    line-height: 1.75;
    color: rgba(245,242,236,0.75);
    margin-bottom: 1.5rem;
    padding-top: 1.5rem;
  }

  .testimonial-author {
    display: flex; align-items: center; gap: 0.75rem;
  }

  .author-avatar {
    width: 38px; height: 38px;
    border-radius: 50%;
    background: var(--accent);
    display: grid; place-items: center;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--white);
    flex-shrink: 0;
  }

  .author-name {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--white);
  }

  .author-detail {
    font-size: 0.78rem;
    color: var(--muted);
    margin-top: 0.15rem;
  }

  .stars { color: var(--accent2); font-size: 0.85rem; margin-bottom: 0.6rem; }

  /* CTA SECTION */
  .cta-section {
    background: var(--accent);
    padding: 6rem 2.5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .cta-section::before {
    content: 'DEVIATION';
    font-family: var(--font-display);
    font-size: 20vw;
    color: rgba(0,0,0,0.08);
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    white-space: nowrap;
    pointer-events: none;
  }

  .cta-inner { position: relative; z-index: 1; }

  .cta-section h2 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 5rem);
    color: var(--white);
    line-height: 1.05;
    margin-bottom: 1rem;
  }

  .cta-section p {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.8);
    font-weight: 300;
    margin-bottom: 2.5rem;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }

  .btn-dark {
    background: var(--black);
    color: var(--white);
    padding: 1rem 2.5rem;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 500;
    font-size: 1.05rem;
    display: inline-flex; align-items: center; gap: 0.5rem;
    transition: transform 0.15s, background 0.2s;
  }
  .btn-dark:hover { background: #222; transform: translateY(-2px); }

  /* FOOTER */
  footer {
    background: #050505;
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 3.5rem 2.5rem 2rem;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer-logo {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--white);
    margin-bottom: 0.5rem;
  }
  .footer-logo span { color: var(--accent); }

  .footer-tagline {
    font-size: 0.85rem;
    color: var(--muted);
    font-weight: 300;
  }

  .footer-col h4 {
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(245,242,236,0.4);
    margin-bottom: 1rem;
  }

  .footer-col ul { list-style: none; }
  .footer-col li { margin-bottom: 0.5rem; }
  .footer-col a {
    font-size: 0.88rem;
    color: rgba(245,242,236,0.6);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-col a:hover { color: var(--white); }

  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.05);
    margin-top: 3rem; padding-top: 1.5rem;
    display: flex; justify-content: space-between; flex-wrap: wrap; gap: 1rem;
    font-size: 0.78rem;
    color: var(--muted);
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
  }

  /* CONTACT FORM */
  .form-section { background: #080808; }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
    max-width: 1100px;
  }
  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .nav-links { display: none; }
    h1 { font-size: clamp(2.8rem, 12vw, 5rem); }
  }

  .form-group { margin-bottom: 1.2rem; }

  .form-group label {
    display: block;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(245,242,236,0.45);
    margin-bottom: 0.5rem;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 6px;
    color: var(--white);
    font-family: var(--font-body);
    font-size: 0.95rem;
    padding: 0.75rem 1rem;
    outline: none;
    transition: border-color 0.2s;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--accent);
  }

  .form-group select {
    appearance: none;
    cursor: pointer;
  }

  .form-group textarea { resize: vertical; min-height: 100px; }

  .form-submit {
    background: var(--accent);
    color: var(--white);
    border: none;
    padding: 0.9rem 2.2rem;
    border-radius: 6px;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    width: 100%;
    transition: background 0.2s;
    letter-spacing: 0.02em;
  }
  .form-submit:hover { background: #c44418; }

  .contact-info-item {
    display: flex; gap: 1rem;
    margin-bottom: 2rem;
    align-items: flex-start;
  }
  .contact-info-icon {
    width: 40px; height: 40px; flex-shrink: 0;
    border: 1px solid rgba(217,79,30,0.3);
    border-radius: 8px;
    display: grid; place-items: center;
    font-size: 1.1rem;
    color: var(--accent);
  }
  .contact-info-label {
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.25rem;
  }
  .contact-info-val {
    font-size: 0.95rem;
    color: var(--white);
    font-weight: 300;
  }

  .max-w { max-width: 1200px; margin: 0 auto; }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <a class="logo" href="#"><span>D</span>eviation Wraps</a>
  <ul class="nav-links">
    <li><a href="#services">Services</a></li>
    <li><a href="#process">Process</a></li>
    <li><a href="#reviews">Reviews</a></li>
    <li><a href="#contact" class="nav-cta">Get a Quote</a></li>
  </ul>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-grid"></div>
  <div class="hero-inner">
    <div class="hero-eyebrow">San Antonio's Wrap Specialists</div>
    <h1>Stand Out.<em>Turn Heads.</em></h1>
    <p class="hero-sub">Premium vehicle wraps, custom decals, and commercial graphics that make your ride — or your brand — impossible to ignore.</p>
    <div class="hero-actions">
      <a href="#contact" class="btn-primary">Get a Free Quote →</a>
      <a href="#services" class="btn-ghost">View Services</a>
    </div>
    <div class="hero-stats">
      <div>
        <div class="hero-stat-num">500+</div>
        <div class="hero-stat-label">Vehicles Wrapped</div>
      </div>
      <div>
        <div class="hero-stat-num">5★</div>
        <div class="hero-stat-label">Avg. Rating</div>
      </div>
      <div>
        <div class="hero-stat-num">7yr</div>
        <div class="hero-stat-label">Film Warranty</div>
      </div>
      <div>
        <div class="hero-stat-num">48hr</div>
        <div class="hero-stat-label">Turnaround</div>
      </div>
    </div>
  </div>
</section>

<!-- TICKER -->
<div class="ticker">
  <div class="ticker-track" aria-hidden="true">
    <span class="ticker-item"><span class="ticker-dot">●</span> Full Vehicle Wraps</span>
    <span class="ticker-item"><span class="ticker-dot">●</span> Color Change Wraps</span>
    <span class="ticker-item"><span class="ticker-dot">●</span> Fleet Graphics</span>
    <span class="ticker-item"><span class="ticker-dot">●</span> Chrome Wraps</span>
    <span class="ticker-item"><span class="ticker-dot">●</span> Paint Protection Film</span>
    <span class="ticker-item"><span class="ticker-dot">●</span> Custom Decals</span>
    <span class="ticker-item"><span class="ticker-dot">●</span> Window Tint</span>
    <span class="ticker-item"><span class="ticker-dot">●</span> Business Signage</span>
    <span class="ticker-item"><span class="ticker-dot">●</span> Partial Wraps</span>
    <span class="ticker-item"><span class="ticker-dot">●</span> Matte Finishes</span>
    <!-- duplicate for seamless loop -->
    <span class="ticker-item"><span class="ticker-dot">●</span> Full Vehicle Wraps</span>
